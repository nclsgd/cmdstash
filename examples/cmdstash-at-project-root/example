#!/usr/bin/env bash
# shellcheck disable=SC2317,SC2329   # silence code unreachability warnings
# vim: set ft=sh ts=4 sw=4 noet ai tw=79:
set -euo pipefail

# Self-relocate within the path of this script:
readonly ORIGINALPWD="${PWD:?}"; cd "${0%"${0##*/}"}."

# Find project base dir to load cmdstash from there and retrieve other
# components from the base location:
PROJECT_BASEDIR="$(set '' ''; cd .; while [ "$2" != / ]; do
[ -f .projectbasedir ] && { echo "${1:-.}"; exit 0; };
set "$1${1:+/}.." "$PWD"; cd ..; done; echo >&2 \
"$0: could not determine PROJECT_BASEDIR by looking up parent dirs"
exit 1)" || exit 1; readonly PROJECT_BASEDIR

CMDSTASH_ORIGINALPWD="$ORIGINALPWD"
. "${PROJECT_BASEDIR:?}/cmdsta.sh"
__CMDSTASH__  # here begins the cmdstash script, do not edit this marker line

# Just a silly command to expose how cmdstash works
CMD helloworld hw -- 'say hello world'
helloworld() {
	echo 'Hello world!'
}
