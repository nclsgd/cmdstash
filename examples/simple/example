#!/bin/sh
# shellcheck disable=SC2317,SC2329   # silence code unreachability warnings
# vim: set ft=sh ts=4 sw=4 noet ai tw=79:
# shellcheck disable=SC3040   # allow pipefail option usage in POSIX sh
set -eu; (set -o pipefail) 2>/dev/null && set -o pipefail

# Save aside the user workdir and change workdir to this script's location:
readonly UWD="${PWD:?}"; cd "${0%"${0##*/}"}."

# Load cmdstash:
CMDSTASH_USERWORKDIR="$UWD"; . ./cmdsta.sh
__CMDSTASH__  # here begins the cmdstash script, do not edit this marker line

# Just a simple command to expose how cmdstash works
CMD helloworld hw -- 'say hello world'
helloworld() {
	echo 'Hello world!'
}
